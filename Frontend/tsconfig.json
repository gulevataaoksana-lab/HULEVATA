{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    
    "noImplicitAny": true,              
    "noUnusedLocals": true,             
    "noUnusedParameters": true,         
    "noImplicitReturns": true,          
    "strictNullChecks": true,           
    
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}